<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.streamdeck.controller</string>
    <key>ProgramArguments</key>
    <array>
        <!-- Replace YOUR_HOME with your home directory path, e.g. /Users/jane -->
        <string>YOUR_HOME/Library/Application Support/StreamDeckController/StreamDeckController</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>YOUR_HOME/Library/Logs/StreamDeckController.log</string>
    <key>StandardErrorPath</key>
    <string>YOUR_HOME/Library/Logs/StreamDeckController.log</string>
</dict>
</plist>
